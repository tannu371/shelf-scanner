# Combined .gitignore for ShelfScanner project

# ============================================
# General (applies to entire project)
# ============================================
.DS_Store
*.swp
*.swo
*~

# ============================================
# Backend (Python)
# ============================================

# Byte-compiled / optimized / DLL files
backend/__pycache__/
backend/**/__pycache__/
backend/**/*.py[cod]
backend/**/*$py.class

# C extensions
backend/**/*.so

# Distribution / packaging
backend/.Python
backend/build/
backend/develop-eggs/
backend/dist/
backend/downloads/
backend/eggs/
backend/.eggs/
backend/lib/
backend/lib64/
backend/parts/
backend/sdist/
backend/var/
backend/wheels/
backend/share/python-wheels/
backend/**/*.egg-info/
backend/.installed.cfg
backend/*.egg
backend/PIPFILE.lock

# PyInstaller
backend/*.manifest
backend/*.spec

# Installer logs
backend/pip-log.txt
backend/pip-delete-this-directory.txt

# Unit test / coverage reports
backend/htmlcov/
backend/.tox/
backend/.nox/
backend/.coverage
backend/.coverage.*
backend/.cache
backend/nosetests.xml
backend/coverage.xml
backend/*.cover
backend/*.py,cover
backend/.hypothesis/
backend/.pytest_cache/
backend/cover/

# Translations
backend/**/*.mo
backend/**/*.pot

# Django/Flask stuff
backend/**/*.log
backend/local_settings.py
backend/db.sqlite3
backend/db.sqlite3-journal
backend/instance/
backend/.webassets-cache

# Scrapy stuff
backend/.scrapy

# Sphinx documentation
backend/docs/_build/

# PyBuilder
backend/.pybuilder/
backend/target/

# Jupyter Notebook
backend/.ipynb_checkpoints
backend/**/*.ipynb_checkpoints

# IPython
backend/profile_default/
backend/ipython_config.py

# pyenv
backend/.python-version

# pipenv
backend/Pipfile.lock

# poetry
backend/poetry.lock

# pdm
backend/.pdm.toml

# PEP 582
backend/__pypackages__/

# Celery stuff
backend/celerybeat-schedule
backend/celerybeat.pid

# SageMath parsed files
backend/**/*.sage.py

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
backend/.env
backend/.venv
backend/env/
backend/venv/
backend/ENV/
backend/env.bak/
backend/venv.bak/

# Spyder project settings
backend/.spyderproject
backend/.spyproject

# Rope project settings
backend/.ropeproject

# mkdocs documentation
backend/site

# mypy
backend/.mypy_cache/
backend/.dmypy.json
backend/dmypy.json

# Pyre type checker
backend/.pyre/

# pytype static type analyzer
backend/.pytype/

# Cython debug symbols
backend/cython_debug/

# ML/Data files (backend specific)
backend/**/*.npy
backend/**/*.h5
backend/**/*.pkl
backend/**/*.pth
backend/**/*.onnx
backend/runs/
backend/data/book_covers/
backend/data/book-dataset/
backend/data/text_dataset/
backend/output/
backend/input/

# ============================================
# Frontend (Flutter/Dart)
# ============================================

# Miscellaneous
frontend/**/*.class
frontend/.buildlog/
frontend/.history
frontend/.svn/
frontend/migrate_working_dir/

# IntelliJ related
frontend/**/*.iml
frontend/**/*.ipr
frontend/**/*.iws
frontend/.idea/

# Visual Studio Code related
frontend/.classpath
frontend/.project
frontend/.settings/
frontend/.vscode/

# Flutter/Dart/Pub related
frontend/**/doc/api/
frontend/.dart_tool/
frontend/.flutter-plugins
frontend/.flutter-plugins-dependencies
frontend/.packages
frontend/.pub-cache/
frontend/.pub/
frontend/build/
frontend/flutter_*.png
frontend/linked_*.ds
frontend/unlinked.ds
frontend/unlinked_spec.ds

# Android related
frontend/android/**/gradle-wrapper.jar
frontend/android/.gradle
frontend/android/captures/
frontend/android/gradlew
frontend/android/gradlew.bat
frontend/android/local.properties
frontend/android/**/GeneratedPluginRegistrant.java
frontend/android/key.properties
frontend/android/**/*.jks

# iOS/XCode related
frontend/ios/**/*.mode1v3
frontend/ios/**/*.mode2v3
frontend/ios/**/*.moved-aside
frontend/ios/**/*.pbxuser
frontend/ios/**/*.perspectivev3
frontend/ios/**/*sync/
frontend/ios/**/.sconsign.dblite
frontend/ios/**/.tags*
frontend/ios/**/.vagrant/
frontend/ios/**/DerivedData/
frontend/ios/**/Icon?
frontend/ios/**/Pods/
frontend/ios/**/.symlinks/
frontend/ios/**/profile
frontend/ios/**/xcuserdata
frontend/ios/.generated/
frontend/ios/Flutter/.last_build_id
frontend/ios/Flutter/App.framework
frontend/ios/Flutter/Flutter.framework
frontend/ios/Flutter/Flutter.podspec
frontend/ios/Flutter/Generated.xcconfig
frontend/ios/Flutter/ephemeral
frontend/ios/Flutter/app.flx
frontend/ios/Flutter/app.zip
frontend/ios/Flutter/flutter_assets/
frontend/ios/Flutter/flutter_export_environment.sh
frontend/ios/ServiceDefinitions.json
frontend/ios/Runner/GeneratedPluginRegistrant.*

# macOS
frontend/macos/Flutter/GeneratedPluginRegistrant.swift
frontend/macos/Flutter/ephemeral

# Linux
frontend/linux/flutter/generated_plugin_registrant.cc
frontend/linux/flutter/generated_plugin_registrant.h
frontend/linux/flutter/generated_plugins.cmake

# Windows
frontend/windows/flutter/generated_plugin_registrant.cc
frontend/windows/flutter/generated_plugin_registrant.h
frontend/windows/flutter/generated_plugins.cmake

# Coverage
frontend/coverage/

# Symbols
frontend/app.*.symbols

# Exceptions to above rules
!frontend/ios/**/default.mode1v3
!frontend/ios/**/default.mode2v3
!frontend/ios/**/default.pbxuser
!frontend/ios/**/default.perspectivev3

# ============================================
# IDE (applies to entire project)
# ============================================
.idea/
.vscode/
*.iml
