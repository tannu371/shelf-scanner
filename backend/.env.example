# ============================================================
#  ShelfScanner — Environment Variables
#  Copy to .env and fill in your values:  cp .env.example .env
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=shelfscanner
DB_USER=postgres
DB_PASSWORD=postgres

# ── External API Keys ────────────────────────────────────────
# Get free key at: https://developers.google.com/books/docs/v1/getting_started
GOOGLE_BOOKS_API_KEY=your_google_books_api_key_here

# ── ML Models ────────────────────────────────────────────────
# SBERT model — change to a smaller model for faster startup if needed
SBERT_MODEL=sentence-transformers/all-mpnet-base-v2
